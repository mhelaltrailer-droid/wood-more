# Copy this file to .env and set your real connection string.
# Do not commit .env (it should be in .gitignore).

# Neon (or any cloud PostgreSQL) – full URL with sslmode=require:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Example (replace with your Neon credentials from the dashboard):
# DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Optional: local PostgreSQL (used only if DATABASE_URL is not set)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=wood_more
# PGUSER=wood_more
# PGPASSWORD=wood_more

# API port (default 3000)
# PORT=3000
