# Wood & More - Environment variables
# Copy this file to .env and fill in your values.
# The .env file is ignored by git for security.

# App
APP_NAME=Wood and More
APP_ENV=development

# API / Backend (optional - for future use)
# API_BASE_URL=https://api.example.com
# API_KEY=your_api_key_here

# Map / Location (optional - if you add a map API key)
# MAP_API_KEY=your_google_maps_or_other_key

# Firebase (optional - if you add Firebase later)
# FIREBASE_API_KEY=
# FIREBASE_PROJECT_ID=
# FIREBASE_APP_ID=
